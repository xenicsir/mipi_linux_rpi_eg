@@ -0,0 +1,141 @@
+/* SPDX-License-Identifier: BSD-2-Clause */
+/*
+ * Copyright (C) 2026, Exosens
+ *
+ * cam_helper_dioneir.cpp - Camera helper for Dione IR sensor
+ */
+
+#include <assert.h>
+#include <stddef.h>
+#include <stdio.h>
+#include <stdlib.h>
+
+#include "cam_helper.h"
+
+using namespace RPiController;
+
+/*
+ * CamHelper for Dione IR
+ *
+ * Sensor characteristics:
+ * - Resolutions: 640×480, 1280×1024, 1024×768, 320×240
+ * - Format: BGR888 (24-bit)
+ * - Interface: Parallel → MIPI CSI-2 (via TC358746 bridge)
+ * - Data lanes: 2
+ * - Link frequencies: 120 MHz, 497 MHz
+ * - Type: Thermal infrared sensor
+ */
+
+class CamHelperDioneir : public CamHelper
+{
+public:
+	CamHelperDioneir();
+	uint32_t gainCode(double gain) const override;
+	double gain(uint32_t gain_code) const override;
+	unsigned int hideFramesStartup() const override;
+	unsigned int hideFramesModeSwitch() const override;
+	unsigned int mistrustFramesStartup() const override;
+	unsigned int mistrustFramesModeSwitch() const override;
+
+private:
+	/*
+	 * Number of frames to hide at startup and during mode switches.
+	 * For this sensor: hide 2 frames at startup (bridge stabilization time)
+	 */
+	static constexpr uint32_t hideFramesStartup_ = 2;
+	static constexpr uint32_t hideFramesModeSwitch_ = 1;
+
+	/*
+	 * Number of frames with potentially incorrect data.
+	 * Used by AGC/AEC algorithms.
+	 */
+	static constexpr uint32_t mistrustFramesStartup_ = 2;
+	static constexpr uint32_t mistrustFramesModeSwitch_ = 1;
+};
+
+CamHelperDioneir::CamHelperDioneir()
+	: CamHelper({}, 1)
+{
+	/*
+	 * frameIntegrationDiff = 1 means exposure changes
+	 * are applied with a 1-frame delay.
+	 *
+	 * Note: This sensor uses a TC358746 bridge between the parallel
+	 * sensor and the MIPI CSI-2 interface. Timing may require adjustment.
+	 */
+}
+
+uint32_t CamHelperDioneir::gainCode(double gain) const
+{
+	/*
+	 * Dione IR: API gain → gain code conversion
+	 *
+	 * This thermal infrared sensor may have limited gain control
+	 * or gain managed by the internal FPGA.
+	 *
+	 * Q4 format: gain_code = gain * 16
+	 * - gain 1.0 → code 16
+	 * - gain 2.0 → code 32
+	 * - gain 8.0 → code 128
+	 */
+	return static_cast<uint32_t>(gain * 16.0);
+}
+
+double CamHelperDioneir::gain(uint32_t gain_code) const
+{
+	/*
+	 * Dione IR: gain code → API gain conversion
+	 */
+	return static_cast<double>(gain_code) / 16.0;
+}
+
+unsigned int CamHelperDioneir::hideFramesStartup() const
+{
+	/*
+	 * Number of frames to hide at startup.
+	 * During this time, AEC/AGC algorithms stabilize and
+	 * the TC358746 bridge initializes.
+	 */
+	return hideFramesStartup_;
+}
+
+unsigned int CamHelperDioneir::hideFramesModeSwitch() const
+{
+	/*
+	 * Number of frames to hide during mode switches
+	 * (e.g., 640×480 → 1280×1024)
+	 */
+	return hideFramesModeSwitch_;
+}
+
+unsigned int CamHelperDioneir::mistrustFramesStartup() const
+{
+	/*
+	 * Frames with potentially incorrect statistics at startup.
+	 */
+	return mistrustFramesStartup_;
+}
+
+unsigned int CamHelperDioneir::mistrustFramesModeSwitch() const
+{
+	/*
+	 * Frames with incorrect data after mode switch.
+	 */
+	return mistrustFramesModeSwitch_;
+}
+
+/*
+ * Register the CamHelper with libcamera.
+ * The name must match the sensor name in the device tree.
+ */
+static CamHelper *create()
+{
+	return new CamHelperDioneir();
+}
+
+/*
+ * Sensor recognition names.
+ * These names must match those returned by the V4L2 driver.
+ */
+static RegisterCamHelper reg("dioneir", &create);
+static RegisterCamHelper reg2("xenics_dione_ir", &create);
