+/* SPDX-License-Identifier: BSD-2-Clause */
+/*
+ * Copyright (C) 2026, Exosens
+ *
+ * cam_helper_eg_ec_mipi.cpp - Camera helper for EngineCore MIPI sensor
+ */
+
+#include <assert.h>
+#include <stddef.h>
+#include <stdio.h>
+#include <stdlib.h>
+
+#include "cam_helper.h"
+
+using namespace RPiController;
+
+/*
+ * CamHelper for EngineCore MIPI (EG-EC-MIPI)
+ *
+ * Sensor characteristics:
+ * - Resolutions: 640×480, 1280×1024
+ * - Formats: UYVY8_1X16, RGB888_1X24, Y16_1X16
+ * - Interface: Native MIPI CSI-2
+ * - Data lanes: 1 or 2 (configurable)
+ * - Link frequency: 240 MHz
+ * - Type: Infrared/thermal sensor
+ * - Integrated EngineCore FPGA
+ */
+
+class CamHelperEgEcMipi : public CamHelper
+{
+public:
+	CamHelperEgEcMipi();
+	uint32_t gainCode(double gain) const override;
+	double gain(uint32_t gain_code) const override;
+	unsigned int hideFramesStartup() const override;
+	unsigned int hideFramesModeSwitch() const override;
+	unsigned int mistrustFramesStartup() const override;
+	unsigned int mistrustFramesModeSwitch() const override;
+
+private:
+	/*
+	 * Number of frames to hide at startup and during mode switches.
+	 * For this sensor: hide 3 frames at startup (FPGA initialization time)
+	 */
+	static constexpr uint32_t hideFramesStartup_ = 3;
+	static constexpr uint32_t hideFramesModeSwitch_ = 2;
+
+	/*
+	 * Number of frames with potentially incorrect data.
+	 * The EngineCore FPGA may require several frames to stabilize
+	 * image processing.
+	 */
+	static constexpr uint32_t mistrustFramesStartup_ = 3;
+	static constexpr uint32_t mistrustFramesModeSwitch_ = 2;
+};
+
+CamHelperEgEcMipi::CamHelperEgEcMipi()
+	: CamHelper({}, 1)
+{
+	/*
+	 * frameIntegrationDiff = 1 means exposure changes
+	 * are applied with a 1-frame delay.
+	 *
+	 * Note: This sensor integrates an EngineCore FPGA that handles
+	 * image processing and format conversion. Delay may require
+	 * adjustment depending on configuration.
+	 */
+}
+
+uint32_t CamHelperEgEcMipi::gainCode(double gain) const
+{
+	/*
+	 * EG-EC-MIPI: API gain → gain code conversion
+	 *
+	 * The EngineCore FPGA can implement digital gain control.
+	 *
+	 * Q4 format: gain_code = gain * 16
+	 * - gain 1.0 → code 16
+	 * - gain 2.0 → code 32
+	 * - gain 8.0 → code 128
+	 */
+	return static_cast<uint32_t>(gain * 16.0);
+}
+
+double CamHelperEgEcMipi::gain(uint32_t gain_code) const
+{
+	/*
+	 * EG-EC-MIPI: gain code → API gain conversion
+	 */
+	return static_cast<double>(gain_code) / 16.0;
+}
+
+unsigned int CamHelperEgEcMipi::hideFramesStartup() const
+{
+	/*
+	 * Number of frames to hide at startup.
+	 * The EngineCore FPGA requires several frames to initialize
+	 * and stabilize image processing.
+	 */
+	return hideFramesStartup_;
+}
+
+unsigned int CamHelperEgEcMipi::hideFramesModeSwitch() const
+{
+	/*
+	 * Number of frames to hide during mode switches
+	 * (e.g., 640×480 → 1280×1024) or format changes (UYVY → RGB → Y16)
+	 */
+	return hideFramesModeSwitch_;
+}
+
+unsigned int CamHelperEgEcMipi::mistrustFramesStartup() const
+{
+	/*
+	 * Frames with potentially incorrect statistics at startup.
+	 */
+	return mistrustFramesStartup_;
+}
+
+unsigned int CamHelperEgEcMipi::mistrustFramesModeSwitch() const
+{
+	/*
+	 * Frames with incorrect data after mode switch.
+	 */
+	return mistrustFramesModeSwitch_;
+}
+
+/*
+ * Register the CamHelper with libcamera.
+ * The name must match the sensor name in the device tree.
+ */
+static CamHelper *create()
+{
+	return new CamHelperEgEcMipi();
+}
+
+/*
+ * Sensor recognition names.
+ * These names must match those returned by the V4L2 driver.
+ */
+static RegisterCamHelper reg("eg-ec-mipi", &create);
